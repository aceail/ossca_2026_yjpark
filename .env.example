# Tomorrow's You — Project env example
# Copy to .env and edit per environment.

# Backend (FastAPI)
TOMORROW_YOU_DB=tomorrow_you.db
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=exaone3.5:7.8b
CORS_ORIGIN=http://localhost:3000
TOMORROW_YOU_FERNET_KEY=        # leave blank → auto-generated to ~/.tomorrow_you/fernet.key

# Frontend (Next.js) — see frontend/.env.example for client-side
NEXT_PUBLIC_API_BASE=http://localhost:8001
